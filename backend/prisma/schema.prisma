datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  leaderboardEntries Leaderboard[]

  // Game/Workflow specifics
  password      String?
  hackerId      String?
  githubId      String?   @unique
  githubToken   String?
  gameSessions  GameSession[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  difficulty  String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  techSelections TechSelection[]
  features       Feature[]
  simulationRun  SimulationRun?

  createdAt   DateTime @default(now())
}

model TechSelection {
  id        String  @id @default(cuid())
  projectId String
  techId    String  // Refers to our hardcoded techItems ID
  
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Feature {
  id          String  @id @default(cuid())
  projectId   String
  title       String
  description String
  effort      Int
  impact      Int
  
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SimulationRun {
  id          String  @id @default(cuid())
  projectId   String  @unique
  innovation  Float
  execution   Float
  design      Float
  pitch       Float
  bonus       Float
  totalScore  Float
  aiFeedback  String
  
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Leaderboard {
  id          String  @id @default(cuid())
  userId      String
  score       Float
  rank        Int?
  
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model GameSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Game Details
  stack           String   // e.g., "MERN", "Next.js + Prisma"
  pace            String   // "HIGH", "MEDIUM", "LOW"
  
  // Problem Statement generated
  problemId       String?
  problem         ProblemStatement? @relation(fields: [problemId], references: [id])
  
  // GitHub Integration
  githubRepoUrl   String?  
  githubRepoName  String?

  // Analysis & Scoring
  currentScore    Float    @default(0)
  analysisResult  String?
  status          String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProblemStatement {
  id          String   @id @default(cuid())
  title       String
  description String
  stack       String
  pace        String
  
  sessions    GameSession[]
}
